# Ask About Me runs in mock mode by default.
# Do not put real secrets in this file.

ASK_API_MODE=mock

# Fill these only in .env.local or hosting provider secrets when real mode is introduced.
LLM_PROVIDER=openai
LLM_MODEL=
LLM_API_KEY=
LLM_MAX_INPUT_CHARS=12000
LLM_MAX_OUTPUT_TOKENS=600
LLM_TIMEOUT_MS=15000

# Initial in-memory policy:
# 20 requests / 10 minutes / client key
RATE_LIMIT_STORE=memory
ASK_RATE_LIMIT_MAX_REQUESTS=20
ASK_RATE_LIMIT_WINDOW_MS=600000

# Production persistent rate limit decision:
# Use Upstash Redis via Vercel Marketplace before enabling public real mode.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
